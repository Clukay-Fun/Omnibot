# Local test profile (minimum required keys)
# Use this only for local dev/smoke. Do not reuse in production.

NANOBOT_INTEGRATIONS__FEISHU__AUTH__APP_ID=cli_local_xxx
NANOBOT_INTEGRATIONS__FEISHU__AUTH__APP_SECRET=local_secret_xxx

# Required only when testing Feishu callback flow locally.
NANOBOT_INTEGRATIONS__FEISHU__OAUTH__ENABLED=false
NANOBOT_INTEGRATIONS__FEISHU__OAUTH__PUBLIC_BASE_URL=
NANOBOT_INTEGRATIONS__FEISHU__OAUTH__CALLBACK_PATH=/oauth/feishu/callback

# Keep SQLite in workspace for local tests.
NANOBOT_INTEGRATIONS__FEISHU__STORAGE__STATE_DB_PATH=
NANOBOT_INTEGRATIONS__FEISHU__STORAGE__SQLITE_JOURNAL_MODE=WAL
NANOBOT_INTEGRATIONS__FEISHU__STORAGE__SQLITE_SYNCHRONOUS=NORMAL
NANOBOT_INTEGRATIONS__FEISHU__STORAGE__SQLITE_BUSY_TIMEOUT_MS=5000

# Optional toggles to keep local behavior simple.
NANOBOT_TOOLS__FEISHU_DATA__FEATURE_FLAGS__CALENDAR_ENABLED=true
NANOBOT_TOOLS__FEISHU_DATA__FEATURE_FLAGS__TASK_ENABLED=true
NANOBOT_TOOLS__FEISHU_DATA__FEATURE_FLAGS__BITABLE_ADMIN_ENABLED=false
NANOBOT_TOOLS__FEISHU_DATA__FEATURE_FLAGS__MESSAGE_HISTORY_ENABLED=false
