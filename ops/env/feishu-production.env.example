# Feishu auth secrets (required)
NANOBOT_INTEGRATIONS__FEISHU__AUTH__APP_ID=
NANOBOT_INTEGRATIONS__FEISHU__AUTH__APP_SECRET=
NANOBOT_INTEGRATIONS__FEISHU__AUTH__ENCRYPT_KEY=
NANOBOT_INTEGRATIONS__FEISHU__AUTH__VERIFICATION_TOKEN=

# OAuth callback and redirect controls
NANOBOT_INTEGRATIONS__FEISHU__OAUTH__ENABLED=true
NANOBOT_INTEGRATIONS__FEISHU__OAUTH__PUBLIC_BASE_URL=https://bot.example.com
NANOBOT_INTEGRATIONS__FEISHU__OAUTH__CALLBACK_PATH=/oauth/feishu/callback
NANOBOT_INTEGRATIONS__FEISHU__OAUTH__ENFORCE_HTTPS_PUBLIC_BASE_URL=true

# Allowed redirect hosts (comma-separated JSON array is recommended in config file)
# Example in config.json:
# "allowedRedirectDomains": ["bot.example.com"]

# SQLite state store and pragma tuning
NANOBOT_INTEGRATIONS__FEISHU__STORAGE__STATE_DB_PATH=/var/lib/nanobot/feishu/state.sqlite3
NANOBOT_INTEGRATIONS__FEISHU__STORAGE__SQLITE_JOURNAL_MODE=WAL
NANOBOT_INTEGRATIONS__FEISHU__STORAGE__SQLITE_SYNCHRONOUS=NORMAL
NANOBOT_INTEGRATIONS__FEISHU__STORAGE__SQLITE_BUSY_TIMEOUT_MS=5000

# Optional tool feature flags
NANOBOT_TOOLS__FEISHU_DATA__FEATURE_FLAGS__CALENDAR_ENABLED=true
NANOBOT_TOOLS__FEISHU_DATA__FEATURE_FLAGS__TASK_ENABLED=true
NANOBOT_TOOLS__FEISHU_DATA__FEATURE_FLAGS__BITABLE_ADMIN_ENABLED=false
NANOBOT_TOOLS__FEISHU_DATA__FEATURE_FLAGS__MESSAGE_HISTORY_ENABLED=true

# Audit retention and memory flush policy
NANOBOT_CHANNELS__FEISHU__AUDIT_CLEANUP_INTERVAL_SECONDS=21600
NANOBOT_CHANNELS__FEISHU__AUDIT_EVENT_RETENTION_DAYS=365
NANOBOT_CHANNELS__FEISHU__AUDIT_MESSAGE_INDEX_RETENTION_DAYS=365
NANOBOT_CHANNELS__FEISHU__MEMORY_FLUSH_THRESHOLD_PRIVATE=3
NANOBOT_CHANNELS__FEISHU__MEMORY_FLUSH_THRESHOLD_GROUP=5
NANOBOT_CHANNELS__FEISHU__MEMORY_FORCE_FLUSH_ON_TOPIC_END=true
