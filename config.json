{
  "agents": {
    "defaults": {
      "workspace": "~/.nanobot/workspace"
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "onboardingEnabled": true,
      "onboardingReentryCommands": [
        "/setup",
        "重新设置"
      ]
    }
  },
  "integrations": {
    "feishu": {
      "auth": {
        "appId": "",
        "appSecret": ""
      },
      "storage": {
        "stateDbPath": "",
        "sqliteJournalMode": "WAL",
        "sqliteSynchronous": "NORMAL",
        "sqliteBusyTimeoutMs": 5000,
        "sqliteBackupDir": "",
        "sqliteBackupIntervalHours": 24,
        "sqliteBackupRetentionDays": 7
      },
      "api": {
        "apiBase": "https://open.feishu.cn"
      },
      "oauth": {
        "enabled": true,
        "publicBaseUrl": "https://your-domain.example.com",
        "callbackPath": "/oauth/feishu/callback",
        "bindHost": "0.0.0.0",
        "bindPort": 18790,
        "scopes": [],
        "stateTtlSeconds": 600,
        "refreshAheadSeconds": 300,
        "enforceHttpsPublicBaseUrl": true,
        "allowedRedirectDomains": [
          "your-domain.example.com"
        ],
        "successHtmlTitle": "Feishu Authorization Completed",
        "failureHtmlTitle": "Feishu Authorization Failed"
      }
    }
  }
}
